/* ... Previous CSS ... */
.power-color i {
    color: #f1c40f;
}

.power-stats {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
}

/* Network Tabs */
.tab-container {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.tab-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    padding: 1rem 1.5rem;
    cursor: pointer;
    font-size: 1rem;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
}

.tab-btn.active {
    color: white;
    border-bottom-color: var(--net-color);
}

.tab-btn:hover {
    color: white;
}